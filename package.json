{
  "name": "@hype/clod",
  "description": "Terminal UI for managing Claude Code sessions.",
  "version": "0.1.0",
  "author": "Nate Goldman <ungoldman@gmail.com>",
  "bin": {
    "clod": "./dist/index.js"
  },
  "bugs": "https://github.com/ungoldman/clod/issues",
  "dependencies": {
    "ink": "^7.1.0",
    "react": "^19.2.7",
    "trash": "^10.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "ink-testing-library": "^4.0.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/ungoldman/clod",
  "keywords": [
    "claude",
    "claude-code",
    "cli",
    "ink",
    "sessions",
    "tui"
  ],
  "license": "ISC",
  "packageManager": "pnpm@11.9.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ungoldman/clod.git"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "coverage": "node --test --experimental-test-coverage --test-coverage-exclude='test/**' --test-coverage-exclude='src/index.ts' --test-coverage-exclude='src/trash.ts' --test-coverage-exclude='src/ui.ts' --test-coverage-lines=100 --test-coverage-branches=100 --test-coverage-functions=100 test/*.test.ts",
    "dev": "node --watch src/index.ts",
    "format": "biome check --write .",
    "lint": "biome check .",
    "prebuild": "rm -rf dist",
    "prepublishOnly": "pnpm build",
    "start": "node src/index.ts",
    "test": "pnpm lint && pnpm typecheck && pnpm build && node --test test/*.test.ts",
    "typecheck": "tsc"
  },
  "type": "module"
}
